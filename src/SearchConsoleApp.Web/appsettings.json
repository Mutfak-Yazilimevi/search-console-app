{
  "ConnectionStrings": {
    "Default": "Server=(localdb)\\mssqllocaldb;Database=SearchConsoleApp;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "App": {
    "Name": "SearchConsoleApp",
    "PublicUrl": "http://localhost:4200",
    "DefaultLanguage": "en",
    "SupportedLanguages": ["en", "tr"]
  },
  "Jwt": {
    "Issuer": "SearchConsoleApp",
    "Audience": "SearchConsoleAppClients",
    "Key": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS_LONG",
    "ExpiresMinutes": 60,
    "RefreshTokenDays": 30
  },
  "TwoFactor": {
    "Issuer": "SearchConsoleApp"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:4201",
      "http://localhost:4202"
    ]
  },
  "Cache": {
    "Provider": "memory",
    "Redis": { "ConnectionString": "localhost:6379" }
  },
  "Email": {
    "Mode": "log",
    "Smtp": {
      "Host": "smtp.example.com",
      "Port": 587,
      "Username": "",
      "Password": "",
      "EnableSsl": true,
      "FromEmail": "noreply@SearchConsoleApp.local",
      "FromName": "SearchConsoleApp"
    }
  },
  "GeoIp": {
    "DatabasePath": "App_Data/GeoLite2-City.mmdb"
  },
  "Blob": {
    "Provider": "local",
    "Local": {
      "RootPath": "App_Data/blobs",
      "PublicBaseUrl": "http://localhost:5000/blobs"
    },
    "S3": {
      "BucketName": "SearchConsoleApp-blobs",
      "Region": "eu-central-1",
      "ServiceUrl": "",
      "AccessKey": "",
      "SecretKey": "",
      "PublicBaseUrl": "",
      "PresignedUrlTtlMinutes": 60
    }
  },
  "Audit": {
    "CaptureChanges": true,
    "CrawlWorkerUrl": "http://localhost:3100",
    "Integrations": {
      "pagespeed": { "Enabled": true },
      "safe-browsing": { "Enabled": true },
      "custom-search": { "Enabled": true },
      "gemini": { "Enabled": true },
      "llm-eeat": { "Enabled": true },
      "oauth-google": { "Enabled": true },
      "backlinks-ahrefs": { "Enabled": false },
      "backlinks-moz": { "Enabled": false },
      "search-console": { "Enabled": true }
    },
    "MaxPages": 50,
    "MaxDepth": 5,
    "RichResultsMaxPages": 10,
    "PageSpeedMaxPages": 20,
    "PageIndexCheckMaxPages": 20,
    "DiscoverImageMaxPages": 10,
    "Schedule": {
      "PollIntervalSeconds": 60
    },
    "CompletionWebhookUrl": "",
    "NotifyEmailOnComplete": true,
    "NotifyOnCriticalOnly": false,
    "KeywordSerpMaxKeywords": 10,
    "WebhookSecret": "",
    "Quota": {
      "MaxConcurrentGlobal": 100,
      "MaxConcurrentPerCustomer": 5,
      "MaxDailyAnonymousGlobal": 200,
      "MaxDailyPerCustomer": 100
    },
    "Storage": "db",
    "Retention": {
      "Mode": "delete",
      "AuditLogDays": 730,
      "RevokedSessionDays": 90,
      "IntervalHours": 24
    }
  },
  "Outbox": {
    "PollIntervalSeconds": 5,
    "BatchSize": 50,
    "MaxAttempts": 8,
    "ClaimTimeoutMinutes": 5,
    "Retention": {
      "SucceededDays": 7,
      "DeadDays": 90,
      "IntervalHours": 24
    }
  },
  "Webhook": {
    "SigningSecret": "CHANGE_THIS_webhook_hmac_secret_for_production"
  },
  "Webhooks": {
    "Receive": {
      "stripe": { "SigningSecret": "" },
      "github": { "SigningSecret": "" }
    }
  },
  "FeatureFlags": {
    "maintenance-mode": false,
    "new-checkout-flow": false,
    "beta-admin-ui": {
      "default": false,
      "enabledForRoles": ["admin"],
      "rolloutPercent": 0
    }
  },
  "RateLimit": {
    "Public": { "PermitLimit": 60, "WindowSeconds": 60 },
    "Web":    { "PermitLimit": 300, "WindowSeconds": 60 },
    "Admin":  { "PermitLimit": 600, "WindowSeconds": 60 },
    "Auth":   { "PermitLimit": 10, "WindowSeconds": 60 },
    "Audit":  { "PermitLimit": 10, "WindowSeconds": 3600 }
  },
  "Realtime": {
    "Enabled": true,
    "DetailedErrors": false,
    "Backplane": {
      "Redis": ""
    }
  },
  "OAuth": {
    "google": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "http://localhost:4200/auth/external/google/callback"
    },
    "microsoft": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "http://localhost:4200/auth/external/microsoft/callback"
    },
    "github": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "http://localhost:4200/auth/external/github/callback"
    }
  },
  "Observability": {
    "OtlpEndpoint": "",
    "ServiceName": "SearchConsoleApp-api",
    "ServiceVersion": "1.0.0",
    "SampleRate": 0.1
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Google": {
    "PageSpeedApiKey": "",
    "SafeBrowsingApiKey": "",
    "CustomSearchApiKey": "",
    "CustomSearchEngineId": "",
    "GeminiApiKey": "",
    "GeminiModel": "gemini-2.5-flash",
    "MerchantCenter": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "http://localhost:4200/auth/merchant-center/callback"
    }
  },
  "Backlinks": {
    "AhrefsApiToken": "",
    "MozAccessId": "",
    "MozSecretKey": ""
  },
  "GoogleSearchConsole": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:4200/auth/search-console/callback"
  },
  "ProductCompliance": {
    "MaxProducts": 100,
    "MaxAiCallsPerRun": 20,
    "PageSpeedMaxProducts": 5
  },
  "Llm": {
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "MaxPages": 20
  },
  "Security": {
    "TokenEncryptionKey": ""
  },
  "AllowedHosts": "*"
}
