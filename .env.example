# Bu dosyayı kopyalayın:  cp .env.example .env
# Sonra tüm stack'i başlatın:  docker compose up -d --build
#
# Yerel adresler:
#   Public UI  → http://localhost:4200
#   Web UI     → http://localhost:4201
#   Admin UI   → http://localhost:4202
#   API        → http://localhost:5000
#   Swagger    → http://localhost:5000/swagger
#
# Google Cloud Console kurulumu:
# 1. https://console.cloud.google.com/apis/credentials
# 2. OAuth consent screen → External → test users'a kendi Gmail'inizi ekleyin
# 3. Credentials → Create OAuth client ID → Web application
# 4. Authorized redirect URIs (ikisini de ekleyin):
#      http://localhost:4200/auth/external/google/callback
#      http://localhost:4200/auth/search-console/callback
#      http://localhost:4200/auth/merchant-center/callback
# 5. Etkinleştirilmesi gereken API'ler:
#      Search Console API
#      Merchant API (Content API for Shopping — GMC bağlı mod için)
#      PageSpeed Insights API
#      Safe Browsing API
#      Google Analytics Data API (GA4 — bağlı mod için)
#      Custom Search JSON API (keyword SERP takibi için)
#
# Merchant Center test adımları: docs/gmc-testing.md
#
# Docker API bu değişkenleri okur (.env otomatik yüklenir).

# --- OAuth (genel giriş) ---
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:4200/auth/external/google/callback

# --- Search Console OAuth (bağlı audit modu) ---
# Boş bırakırsanız OAuth:google değerleri kullanılır
GOOGLE_SC_CLIENT_ID=
GOOGLE_SC_CLIENT_SECRET=
GOOGLE_SC_REDIRECT_URI=http://localhost:4200/auth/search-console/callback

# --- Merchant Center OAuth (ürün uyumluluk — bağlı mod) ---
# Boş bırakırsanız OAuth:google değerleri kullanılır
GOOGLE_GMC_CLIENT_ID=
GOOGLE_GMC_CLIENT_SECRET=
GOOGLE_GMC_REDIRECT_URI=http://localhost:4200/auth/merchant-center/callback

# --- Google API anahtarları (opsiyonel; ilgili özellikler devre dışı kalır) ---
GOOGLE_PAGESPEED_API_KEY=
GOOGLE_SAFEBROWSING_API_KEY=
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# Gemini (SSS / FAQ AI üretimi — yalnızca sunucuda kullanılır, frontend'e gönderilmez)
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-2.5-flash

# --- Crawl worker ↔ API webhook güvenliği (production'da zorunlu) ---
# Aynı değer hem API (Audit__WebhookSecret) hem worker (AUDIT_WEBHOOK_SECRET) için kullanılır
AUDIT_WEBHOOK_SECRET=

# Ürün uyumluluk crawl webhook (Docker'da crawl-worker → api)
PRODUCT_COMPLIANCE_WEBHOOK_URL=http://localhost:5000/api/v1/public/merchant-center/compliance/webhook

# Ürün fiyat analizi — Google Shopping
# Docker'da Google genelde CAPTCHA verir; SERP_API_KEY önerilir (https://serpapi.com)
SHOPPING_SEARCH_DELAY_MS=2000
SHOPPING_BROWSER_ENABLED=true
SHOPPING_MAX_OFFERS=20
SHOPPING_USE_SERPAPI=false
SERP_API_KEY=

# --- Harici backlink API'leri (opsiyonel) ---
AHREFS_API_TOKEN=
MOZ_ACCESS_ID=
MOZ_SECRET_KEY=
